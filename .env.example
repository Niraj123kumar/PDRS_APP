PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000
DB_PATH=./pdrs.db
JWT_SECRET=your_jwt_secret_here
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
SESSION_SECRET=random_string
ENCRYPTION_KEY=64_hex_chars_random
ADMIN_EMAIL=your_admin_email@domain.com

# AI Providers
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Auth & Calendar
GOOGLE_CLIENT_ID=from_google_console
GOOGLE_CLIENT_SECRET=from_google_console
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# GitHub
GITHUB_TOKEN=optional_for_higher_rate_limits

# Twilio (SMS/WhatsApp)
TWILIO_ACCOUNT_SID=from_twilio_console
TWILIO_AUTH_TOKEN=from_twilio_console
TWILIO_PHONE_NUMBER=+1234567890

# Push Notifications
VAPID_PUBLIC_KEY=generate_with_web-push
VAPID_PRIVATE_KEY=generate_with_web-push
VAPID_EMAIL=mailto:your@email.com

# Integrations
SLACK_BOT_TOKEN=
ZOOM_API_KEY=
ZOOM_API_SECRET=
ZOOM_ACCOUNT_ID=
LMS_MOODLE_URL=
LMS_MOODLE_TOKEN=

# Infrastructure
REDIS_URL=redis://localhost:6379
SENTRY_DSN=
